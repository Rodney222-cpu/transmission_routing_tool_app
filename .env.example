# Flask Configuration
FLASK_CONFIG=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here-change-in-production

# Optional map tile API keys (dashboard basemaps)
MAPTILER_API_KEY=#
THUNDERFOREST_API_KEY=#

# Database
DATABASE_URL=sqlite:///transmission_routing.db

# For production, use PostgreSQL with PostGIS:
# DATABASE_URL=postgresql://user:password@localhost/transmission_routing

